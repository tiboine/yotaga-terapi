---

<section id="bestill" class="py-20 sm:py-28 bg-bg">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-secondary font-medium text-sm uppercase tracking-widest mb-3">Booking</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-dark mb-4">
        Bestill time
      </h2>
      <p class="text-text-light max-w-2xl mx-auto leading-relaxed">
        Velg behandling og tidspunkt som passer deg. Enkel og rask booking via Timma.
      </p>
    </div>

    <div class="bg-surface rounded-2xl p-4 sm:p-6 shadow-sm">
      <iframe
        src="https://timma.no/salong/yotaga-terapi"
        title="Bestill time hos Yotaga Terapi"
        width="100%"
        height="700"
        frameborder="0"
        loading="lazy"
        allow="payment"
        class="w-full rounded-xl border-0 min-h-[600px]"
        style="height: 700px;"
      ></iframe>
    </div>

    <div class="mt-6 text-center">
      <p class="text-text-light text-sm">
        Problemer med booking? Gå direkte til
        <a
          href="https://timma.no/salong/yotaga-terapi"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary-dark font-medium underline hover:text-primary transition-colors"
        >
          Timma.no
        </a>
      </p>
    </div>
  </div>
</section>
