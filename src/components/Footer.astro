---
const year = new Date().getFullYear();
---

<footer class="bg-primary-dark text-white/80 py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-10">
      <!-- Brand -->
      <div>
        <h3 class="text-xl font-bold text-white mb-3">Yotaga Terapi</h3>
        <p class="text-sm leading-relaxed text-white/60">
          Thaimassasje og homeopati i Nord-Norge.
          Din vei til velvære og balanse.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-semibold text-white mb-3">Snarveier</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#om-meg" class="hover:text-secondary transition-colors">Om meg</a></li>
          <li><a href="#tjenester" class="hover:text-secondary transition-colors">Tjenester</a></li>
          <li><a href="#bestill" class="hover:text-secondary transition-colors">Bestill time</a></li>
          <li><a href="#kontakt" class="hover:text-secondary transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h4 class="font-semibold text-white mb-3">Informasjon</h4>
        <ul class="space-y-2 text-sm">
          <li>Org.nr: 916 318 782</li>
          <li>Medlem av NLH</li>
          <li>
            <a
              href="https://www.facebook.com/Yotagaterapi"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-secondary transition-colors"
            >
              Facebook
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-6 text-center text-sm text-white/40">
      <p>&copy; {year} Yotaga Terapi. Alle rettigheter reservert.</p>
    </div>
  </div>
</footer>
