---

---

<section class="relative min-h-[90vh] flex items-center justify-center text-white overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img src="/images/room.jpg" alt="Yotaga Terapi behandlingsrom" class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-black/40"></div>
  </div>

  <div class="relative z-10 text-center px-4 sm:px-6 max-w-3xl mx-auto pt-16">
    <p class="text-secondary font-medium text-sm sm:text-base uppercase tracking-widest mb-4">
      Thaimassasje & Homeopati
    </p>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
      Yotaga Terapi
    </h1>
    <p class="text-lg sm:text-xl text-white/85 leading-relaxed mb-10 max-w-2xl mx-auto">
      Opplev tradisjonell thaimassasje og naturlig helbredelse gjennom homeopati.
      Din vei til velvere og balanse starter her.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#bestill"
        class="inline-block bg-secondary hover:bg-secondary/90 text-text font-semibold px-8 py-4 rounded-xl transition-colors text-base"
      >
        Bestill time
      </a>
      <a
        href="#tjenester"
        class="inline-block border-2 border-white/30 hover:border-white/60 text-white font-medium px-8 py-4 rounded-xl transition-colors text-base"
      >
        Våre tjenester
      </a>
    </div>
  </div>
</section>
