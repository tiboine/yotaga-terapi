---
const testimonials = [
  {
    name: 'Tordis B.',
    text: 'Utrolig bra massasje! Fine omgivelser og hyggelig behandler. Blir ikke siste gangen!',
    service: 'Dypvevsmassasje',
    rating: 5,
  },
  {
    name: 'Marita B.',
    text: 'Beste massasjen jeg har fått, veldig dyktig dame!',
    service: 'Tradisjonell thaimassasje',
    rating: 5,
  },
  {
    name: 'Ronalyn D.',
    text: 'Veldig avslappende. Anbefales for de som har jobb som krever fysisk eller tungt arbeid, hjelper å løsne kroppen.',
    service: 'Dypvevsmassasje',
    rating: 5,
  },
  {
    name: 'Gunn E.',
    text: 'Veldig bra, anbefales!',
    service: 'Nakke/rygg/skuldermassasje',
    rating: 5,
  },
  {
    name: 'Irene P.',
    text: 'Dyktig behandler.',
    service: 'Aromamassasje',
    rating: 5,
  },
  {
    name: 'Kunde',
    text: 'Fantastisk opplevelse fra start til slutt. Wanpen er utrolig flink og profesjonell.',
    service: 'Tradisjonell thaimassasje',
    rating: 5,
  },
];
---

<section class="py-20 sm:py-28 bg-bg">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-secondary font-medium text-sm uppercase tracking-widest mb-3">Anmeldelser</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-dark mb-4">
        Hva kundene sier
      </h2>
      <div class="flex items-center justify-center gap-2 mb-2">
        {[...Array(5)].map(() => (
          <svg class="w-6 h-6 text-secondary" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
          </svg>
        ))}
      </div>
      <p class="text-text-light">
        5.0 av 5 basert på <span class="font-semibold text-text">152 anmeldelser</span> på Timma
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map(t => (
        <div class="bg-surface rounded-2xl p-6 sm:p-8 shadow-sm">
          <div class="flex gap-1 mb-4">
            {[...Array(t.rating)].map(() => (
              <svg class="w-4 h-4 text-secondary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>
          <p class="text-text leading-relaxed mb-4">"{t.text}"</p>
          <div class="border-t border-bg pt-4">
            <p class="font-semibold text-primary-dark text-sm">{t.name}</p>
            <p class="text-text-light text-xs">{t.service}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-10">
      <a
        href="https://timma.no/salong/yotaga-terapi"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-primary-dark font-semibold hover:text-primary transition-colors"
      >
        Se alle 152 anmeldelser på Timma
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
