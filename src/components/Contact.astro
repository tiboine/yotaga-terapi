---
interface Props {
  phone: string;
  email: string;
  facebook: string;
  location: string;
}
const { phone, email, facebook, location } = Astro.props;
const phoneClean = phone.replace(/\s/g, '');
---

<section id="kontakt" class="py-20 sm:py-28 bg-surface">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-secondary font-medium text-sm uppercase tracking-widest mb-3">Kontakt</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-primary-dark mb-4">
        Ta kontakt
      </h2>
      <p class="text-text-light max-w-2xl mx-auto leading-relaxed">
        Har du spørsmål om behandlinger eller ønsker mer informasjon? Ikke nøl med å ta kontakt.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Phone -->
      <div class="bg-bg rounded-2xl p-8 text-center shadow-sm">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-5">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <h3 class="font-semibold text-primary-dark mb-2">Telefon</h3>
        <a href={`tel:${phoneClean}`} class="text-text-light hover:text-primary-dark transition-colors">
          {phone}
        </a>
      </div>

      <!-- Email -->
      <div class="bg-bg rounded-2xl p-8 text-center shadow-sm">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-5">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <h3 class="font-semibold text-primary-dark mb-2">E-post</h3>
        <a href={`mailto:${email}`} class="text-text-light hover:text-primary-dark transition-colors">
          {email}
        </a>
      </div>

      <!-- Facebook -->
      <div class="bg-bg rounded-2xl p-8 text-center shadow-sm sm:col-span-2 lg:col-span-1">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mx-auto mb-5">
          <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </div>
        <h3 class="font-semibold text-primary-dark mb-2">Facebook</h3>
        <a
          href={facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-light hover:text-primary-dark transition-colors"
        >
          @Yotagaterapi
        </a>
      </div>
    </div>

    <!-- Location info -->
    <div class="mt-12 bg-bg rounded-2xl p-8 shadow-sm">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
          <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-primary-dark mb-2">Lokasjon</h3>
          <p class="text-text-light leading-relaxed">{location}</p>
        </div>
      </div>
    </div>
  </div>
</section>
